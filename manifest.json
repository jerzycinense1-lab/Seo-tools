{
  "manifest_version": 3,
  "name": "SEO Tools Pro",
  "version": "4.0.0",
  "description": "Complete SEO toolkit with 50+ tools, AI features, email templates, and advanced website analysis. Created by SearchWorks.ph",
  "homepage_url": "https://searchworks.ph",
  
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "tabs",
    "storage",
    "scripting",
    "alarms",
    "contextMenus"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "SEO Tools Pro"
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils.js", "seo-tools.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["utils.js", "seo-tools.js"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "commands": {
    "toggle-extension": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Toggle extension popup"
    }
  }
}